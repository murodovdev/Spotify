# ─────────────────────────────────────────────────────────────────────────────
# TrackFlow — environment configuration
# Copy this file to `.env` and fill in the values. Only BOT_TOKEN is required.
# ─────────────────────────────────────────────────────────────────────────────

# [REQUIRED] Telegram bot token from @BotFather.
BOT_TOKEN=123456:ABC-DEF...

# ── Spotify API (optional) ───────────────────────────────────────────────────
# Enables full Spotify link resolution and Liked Songs. Without these the bot
# runs in "embed mode" (public metadata + YouTube search; Liked Songs disabled).
# Create an app at https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# OAuth redirect URI. Leave blank to auto-derive:
#   Railway → https://<domain>/callback   Local → http://127.0.0.1:<PORT>/callback
# The value here must exactly match a Redirect URI in your Spotify app settings.
SPOTIFY_REDIRECT_URI=

# ── Admin & security (optional) ──────────────────────────────────────────────
# Telegram user ID granted owner/admin access (enables /admin).
ADMIN_ID=0

# Fernet key used to encrypt stored user tokens. Derived from BOT_TOKEN if blank.
ENCRYPTION_KEY=

# ── Storage (optional) ───────────────────────────────────────────────────────
# SQLite database path. Leave blank to auto-select:
#   Railway → /data/bot.db (requires a mounted volume!)   Local → data/bot.db
# On Railway, ALWAYS attach a volume at /data or every redeploy wipes user data.
DB_PATH=

# ── Runtime (optional) ───────────────────────────────────────────────────────
# Port for the OAuth web server / health check.
PORT=8080

# Maximum number of concurrent downloads.
MAX_DOWNLOADS=4

# ── Recommendations (optional) ───────────────────────────────────────────────
# Last.fm API key: https://www.last.fm/api/account/create
# The "similar songs" engine works fully without it (ListenBrainz + Deezer +
# local audio analysis); a key adds tag and getSimilar signals.
LASTFM_API_KEY=

# ── YouTube cookies (optional, recommended on Railway) ───────────────────────
# Data-center IPs are often flagged by YouTube ("Sign in to confirm you're not
# a bot") and age-restricted videos are refused. Exported login cookies fix this.
# Export a cookies.txt (Netscape format) with a browser extension, then set ONE:
#   YOUTUBE_COOKIES      — raw cookies.txt contents
#   YOUTUBE_COOKIES_B64  — base64-encoded cookies.txt (convenient for Railway)
#   YOUTUBE_COOKIES_FILE — path to a cookies file, e.g. /data/cookies.txt
YOUTUBE_COOKIES=
YOUTUBE_COOKIES_B64=
YOUTUBE_COOKIES_FILE=
