# Telegram bot token (@BotFather dan olinadi)
BOT_TOKEN=123456:ABC-DEF...

# Spotify API kalitlari (https://developer.spotify.com/dashboard)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Ixtiyoriy: OAuth redirect URI (bo'sh qoldirilsa avtomatik aniqlanadi:
# Railway'da https://<domain>/callback, lokalda http://127.0.0.1:<PORT>/callback)
SPOTIFY_REDIRECT_URI=

# Ixtiyoriy: admin Telegram ID (/stats buyrug'i uchun)
ADMIN_ID=0

# Ixtiyoriy: tokenlarni shifrlash kaliti (bo'sh qoldirilsa BOT_TOKEN dan hosil qilinadi)
ENCRYPTION_KEY=

# SQLite fayl yo'li. MUHIM: Railway'da bo'sh qoldiring YOKI /data/bot.db qiling
# VA /data ga Volume mount qiling. Aks holda har redeploy'da BARCHA foydalanuvchi
# ma'lumoti yo'qoladi! Bo'sh qoldirilsa: Railway'da avtomat /data/bot.db, lokalda
# data/bot.db ishlatiladi.
DB_PATH=

# OAuth web-server porti
PORT=8080

# Ixtiyoriy, LEKIN Railway'da TAVSIYA ETILADI: YouTube cookies.txt.
# YouTube data-markaz IP'larini "bot" deb bloklaydi ("Sign in to confirm you're
# not a bot") va yosh-cheklovli videolarni rad etadi. Logindan olingan cookie
# buni hal qiladi. Brauzer kengaytmasi bilan cookies.txt (Netscape formati)
# eksport qiling, so'ng quyidagilardan BIRINI to'ldiring:
#   YOUTUBE_COOKIES       — cookies.txt matnini to'g'ridan-to'g'ri
#   YOUTUBE_COOKIES_B64   — base64 bilan kodlangan cookies.txt (Railway uchun qulay)
#   YOUTUBE_COOKIES_FILE  — volume ichidagi fayl yo'li, masalan /data/cookies.txt
YOUTUBE_COOKIES=
YOUTUBE_COOKIES_B64=
YOUTUBE_COOKIES_FILE=

# Ixtiyoriy: Last.fm API kaliti (https://www.last.fm/api/account/create)
# "O'xshash qo'shiqlar" dvigateli kalitsiz ham to'liq ishlaydi (ListenBrainz +
# Deezer + lokal audio-tahlil); kalit qo'shilsa teglar va getSimilar signallari
# bilan yanada kuchayadi.
LASTFM_API_KEY=
